# =============================================================================
# Stratum — .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Environment files — secrets must NEVER be committed
# .env.example is committed (placeholder values only)
# ---------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
.env.*.local

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.pyc
.Python
build/
dist/
*.egg-info/
.eggs/
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover
*.log

# ---------------------------------------------------------------------------
# Node.js / Next.js
# ---------------------------------------------------------------------------
node_modules/
.next/
out/
.npm
*.tgz
.eslintcache
.parcel-cache
.pnp.*

# ---------------------------------------------------------------------------
# macOS
# ---------------------------------------------------------------------------
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.Spotlight-V100
.Trashes
.DocumentRevisions-V100
.fseventsd
.TemporaryItems

# ---------------------------------------------------------------------------
# JetBrains / VS Code / editors
# ---------------------------------------------------------------------------
.idea/
*.iml
.vscode/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Docker local state
# ---------------------------------------------------------------------------
# Note: docker-compose.override.yml is committed (contains no secrets, only local dev config)
# docker-compose.override.yml

# ---------------------------------------------------------------------------
# Build artifacts
# ---------------------------------------------------------------------------
*.so
*.o
