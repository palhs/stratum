      "id": "wait-markers",
      "name": "Wait (Markers)",
      "type": "n8n-nodes-base.wait",
      "typeVersion": 1.1,
      "position": [3200, 460]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict"
          },
          "conditions": [
            {
              "id": "anomaly-check-ohlcv",
              "leftValue": "={{ $('Ingest vnstock OHLCV').first().json.anomaly_detected }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            },
            {
              "id": "anomaly-check-fundamentals",
              "leftValue": "={{ $('Ingest vnstock Fundamentals').first().json.anomaly_detected }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "or"
        }
      },
      "id": "check-anomalies",
      "name": "Any Anomaly Detected?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [3220, 300]
    },
    {
      "parameters": {
        "chatId": "={{ $env.TELEGRAM_CHAT_ID }}",
        "text": "=\u26a0\ufe0f *Row Count Anomaly Detected*\n*Workflow:* Weekly Data Pipeline\n*OHLCV anomaly:* {{ $('Ingest vnstock OHLCV').first().json.anomaly_detected }}\n*Fundamentals anomaly:* {{ $('Ingest vnstock Fundamentals').first().json.anomaly_detected }}\n*Time:* {{ $now.toISO() }}\n\n_This is a warning only — data was ingested successfully._",
        "additionalFields": {
          "parse_mode": "Markdown"
        }
      },
      "id": "telegram-anomaly-alert",
      "name": "Telegram Anomaly Alert",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [3440, 200],
      "credentials": {
        "telegramApi": {
          "id": "telegram-bot",
          "name": "Telegram Bot"
        }
      }
    }
