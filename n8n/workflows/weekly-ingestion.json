      "typeVersion": 1.1,
      "position": [1520, 460]
    },
    {
      "parameters": {
        "url": "http://data-sidecar:8000/ingest/gold/fred-price",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"start_date\": \"{{ $('Set Date Range').first().json.start_date }}\",\n  \"end_date\": \"{{ $('Set Date Range').first().json.end_date }}\"\n}",
        "options": {
          "timeout": 300000
        }
      },
      "id": "ingest-gold-fred",
      "name": "Ingest Gold FRED Price",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1740, 300],
