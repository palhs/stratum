            "type": "main",
            "index": 0
          }
        ]
      ]
    },
    "Wait (Gold Markers)": {
      "main": [
        [
          {
            "node": "Compute Gold Structure Markers",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
