# =============================================================================
# Stratum — Environment Template
# Copy to .env.local for local development (gitignored).
# Copy to .env.production for VPS deployment (gitignored).
# =============================================================================

# PostgreSQL (Stratum primary data store)
POSTGRES_USER=stratum
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stratum

# PostgreSQL (n8n metadata — separate database within the same PostgreSQL instance)
N8N_DB_NAME=n8n_meta
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

# Neo4j
# Generate: openssl rand -hex 12
NEO4J_PASSWORD=changeme

# Qdrant
# Generate: openssl rand -hex 16
QDRANT_API_KEY=changeme

# n8n
# CRITICAL: generate once and never change — losing this key breaks all stored credentials
# Generate: openssl rand -hex 16
N8N_ENCRYPTION_KEY=generate-a-random-32-char-string

# vnstock (Phase 2 — Vietnamese stock data)
# Optional but recommended: Community tier raises rate limit from 20 to 60 req/min.
# Needed for VN30 batch ingestion and 5-year backfill without throttling.
# Free Community tier: https://vnstocks.com/login — sign in with Google
VNSTOCK_API_KEY=your-vnstock-api-key-here

# FRED (Phase 2 — macroeconomic indicators and gold price)
# Required for gold price (GOLDAMGBD228NLBM), Federal Funds Rate (DFF),
# yield spread (T10Y2Y), CPI (CPIAUCSL), and US Dollar Index (DTWEXBGS).
# Free registration: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your-fred-api-key-here

# Google Gemini API (Phase 3+ — reasoning-engine service)
# Required for bilingual report generation in the v2.0 reasoning pipeline.
# The google-genai SDK auto-detects GEMINI_API_KEY from the environment.
# Get key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Telegram Bot (Phase 2 — pipeline failure and anomaly alerts via n8n)
# Create bot: https://t.me/BotFather → /newbot → copy token
# Get chat ID: send any message to bot, then GET https://api.telegram.org/bot<TOKEN>/getUpdates → result.message.chat.id
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-chat-id

# Supabase Auth (Phase 11)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-anon-key
SUPABASE_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json

# VPS Host (Phase 12 — deprecated in Phase 15, use NEXT_PUBLIC_API_URL instead)
# VPS_HOST=your-vps-ip

# nginx / TLS (Phase 15)
DOMAIN=stratum.example.com
CERTBOT_EMAIL=admin@example.com
NEXT_PUBLIC_API_URL=https://stratum.example.com
