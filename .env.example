# =============================================================================
# Stratum — Environment Template
# Copy to .env.local for local development (gitignored).
# Copy to .env.production for VPS deployment (gitignored).
# =============================================================================

# PostgreSQL (Stratum primary data store)
POSTGRES_USER=stratum
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stratum

# PostgreSQL (n8n metadata — separate database within the same PostgreSQL instance)
N8N_DB_NAME=n8n_meta
N8N_DB_USER=n8n
N8N_DB_PASSWORD=changeme

# Neo4j
# Generate: openssl rand -hex 12
NEO4J_PASSWORD=changeme

# Qdrant
# Generate: openssl rand -hex 16
QDRANT_API_KEY=changeme

# n8n
# CRITICAL: generate once and never change — losing this key breaks all stored credentials
# Generate: openssl rand -hex 16
N8N_ENCRYPTION_KEY=generate-a-random-32-char-string
